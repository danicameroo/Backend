<h1 style="color:blue;">Ingrese datos</h1>
<br>

<form action="/productos" method="post">

    <div class="form-group">
        <label for="nombre"><b>Nombre</b></label>
        <input id="nombre" class="form-control" type="text" name="nombre">
    </div>

    <div class="form-group">
        <label for="precio"><b>Precio</b></label>
        <input id="precio" class="form-control" type="number" name="precio">
    </div>

    <div class="form-group">
        <label for="foto"><b>Foto url</b></label>
        <input id="foto" class="form-control" type="url" name="foto">
    </div>

    <button class="btn btn-success mt-3 mb-5">Enviar</button>
</form>

<h2 style="color:crimson;">Historial</h2>

 {{#if productos.length}}
        <div class="table-responsive">
            <table class="table table-dark">
                <tr style="color: black;">
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Foto</th>
                </tr>

                {{#each productos}}
                <tr>
                    <td>
                        {{productos.nombre}}
                    </td>
                    <td>
                        {{productos.precio}}
                    </td>
                    <td>
                        {{productos.foto}}
                    </td>
                </tr>
                {{/each}}
            </table>
        </div>
        {{else}}
        <h3 class="alert alert-danger">No products</h3>
        {{/if}}